# capstone LLM 제공자 설정 예시
#
# 사용법:
#   cp .env.example .env      # 이 파일을 복사
#   # .env 에서 LLM_PROVIDER 와 해당 제공자의 키만 채운다
#   docker-compose up -d frontend   # 또는 frontend 재시작
#
# .env 는 .gitignore 로 추적 제외(키 노출 방지). 이 .env.example 만 커밋된다.

# ── 제공자 선택 ──────────────────────────────────────────────
# ollama(기본) | openai | anthropic | gemini | openai-compatible
LLM_PROVIDER=ollama

# 모델명(미지정 시 제공자별 기본값 사용)
#  - ollama:    llama3.1:8b
#  - openai:    gpt-4o-mini
#  - anthropic: claude-3-5-haiku-latest
#  - gemini:    gemini-2.0-flash
LLM_MODEL=

# ── 제공자별 API 키 (쓰는 것만 채우면 됨) ───────────────────
# OpenAI / OpenAI 호환(LM Studio·vLLM·Together·Groq 등)
OPENAI_API_KEY=
# 호환 서버를 쓸 때만 base URL 지정 (예: http://localhost:1234/v1 는 /v1 없이 http://localhost:1234)
OPENAI_BASE_URL=

# Anthropic Claude
ANTHROPIC_API_KEY=

# Google Gemini
GEMINI_API_KEY=
