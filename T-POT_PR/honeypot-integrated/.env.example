# ────────────────────────────────────────────────────────────────────────────
# Honeypot Integrated Platform — 환경변수 템플릿
#
# 사용법:
#   cp .env.example .env
#   .env 파일의 값들을 실제 환경에 맞게 수정한 뒤 docker compose up -d --build
# ────────────────────────────────────────────────────────────────────────────


# ─── 호스트 경로 (반드시 본인 환경에 맞게 수정) ───────────────────────────────
# Docker Desktop on Windows + WSL2 백엔드:    /mnt/d/...
# Docker Desktop on Windows (PowerShell 직접): D:/...
# 두 형식을 섞으면 일부 컨테이너가 다른 파일 시스템 뷰를 보게 되므로 통일할 것.

PROJECT_HOST=/mnt/d/joljak33-main/honeypot-integrated
HONEYPOT_LOGS_HOST=/mnt/d/honeypot_logs


# ─── 보안 (운영 환경에서 반드시 변경) ─────────────────────────────────────────
# SECRET_KEY: openssl rand -hex 32  로 생성 권장
# 비어있으면 컨테이너 재시작 시 발급된 JWT가 모두 무효화됨

SECRET_KEY=change-me-in-production-32-bytes-or-more


# ─── PostgreSQL (Spring Boot 프로파일링 서비스 전용) ─────────────────────────
POSTGRES_DB=honeypot_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-password

# 백엔드(FastAPI) ↔ 프로파일링(Spring Boot) 내부 통신 토큰
INTERNAL_SERVICE_TOKEN=change-me-internal-shared-token


# ─── 허니팟 네트워크 ─────────────────────────────────────────────────────────
# 다른 도커 네트워크와 충돌하지 않는 대역 사용

SUBNET=172.30.0.0/24
COWRIE_IP=172.30.0.10
HERALDING_IP=172.30.0.11
OPENCANARY_IP=172.30.0.12
SNARE_IP=172.30.0.13
DIONAEA_IP=172.30.0.14
MAILONEY_IP=172.30.0.15
CONPOT_IP=172.30.0.16
TANNER_IP=172.30.0.17
KALI_IP=172.30.0.20
